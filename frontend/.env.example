# Frontend Environment Variables
# Copy this to .env.local for local dev, or set in Vercel dashboard

# ── API URL ─────────────────────────────────────────────────────────────────
# Leave blank for local dev (Vite proxy handles /api/* → localhost:5000)
# On Vercel: set this to your Render backend URL
VITE_API_URL=https://karm-ai-api.onrender.com
