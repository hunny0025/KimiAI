# backend/.env
# Copy this file to .env and fill in your actual values.
# Never commit .env to version control.

# ── PostgreSQL Connection ────────────────────────────────────────────────────
# Format: postgresql+psycopg2://<user>:<password>@<host>:<port>/<dbname>
DATABASE_URL=postgresql+psycopg2://skillgenome:skillgenome@localhost:5432/skillgenome

# ── Flask Settings ───────────────────────────────────────────────────────────
FLASK_ENV=development
FLASK_DEBUG=1

# ── KARM.AI — Groq LLM Key (Policy Agent) ───────────────────────────────────
# Sign up free at https://console.groq.com — model: llama3-8b-8192
# Without this key, Policy Agent falls back to the deterministic rule engine.
GROQ_API_KEY=your_groq_api_key_here
